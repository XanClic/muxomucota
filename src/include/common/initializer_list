#ifndef _INITIALIZER_LIST
#define _INITIALIZER_LIST

#include <cstddef>


namespace std
{

template <typename E> class initializer_list {
    public:
        typedef       E  value_type;
        typedef const E &reference;
        typedef const E &const_reference;
        typedef size_t   size_type;
        typedef const E *iterator;
        typedef const E *const_iterator;

    private:
        iterator array;
        size_type length;

        constexpr initializer_list(const_iterator a, size_type l): array(a), length(l) {}

    public:
        constexpr initializer_list(void) noexcept: array(nullptr), length(0) {}

        constexpr size_type      size (void) const noexcept { return length; }
        constexpr const_iterator begin(void) const noexcept { return array; }
        constexpr const_iterator end  (void) const noexcept { return array + length; }
};

template <typename E> constexpr typename initializer_list<E>::const_iterator begin(initializer_list<E> init_list) noexcept
{ return init_list.begin(); }

template <typename E> constexpr typename initializer_list<E>::const_iterator end(initializer_list<E> init_list) noexcept
{ return init_list.end(); }

}

#endif
